  "keyFeatures": [
    "Type-safe API wrapper with full TypeScript support",
    "750+ endpoints (650+ classic + 95+ OpenCloud)",
    "Automatic pagination and batch processing",
    "Built-in authentication with cookie pools and rotation",
    "Advanced security features (XCSRF, HBA, challenge handling)",
    "Universal runtime support (Node.js, Bun, Deno, Browser)",
    "Custom endpoint definitions with Zod validation",
    "Production-tested with 800,000+ active users"
  ],
  "publicApiSurface": [
    "fetchApi - Main function for making API requests",
    "fetchApiPages - Fetch all pages of paginated responses",
    "fetchApiPagesGenerator - Stream paginated responses",
    "fetchApiSplit - Batch process large requests",
    "endpoint - Define custom endpoints with type safety",
    "configureServer - Configure authentication and settings",
    "setHandleGenericChallenge - Handle authentication challenges",
    "refreshCookie - Manually refresh authentication cookies",
    "getCookies - Get current cookie values",
    "updateCookie - Update cookie in pool",
    "clearServerConfig - Clear server configuration",
    "getServerConfig - Get current server configuration",
    "changeHBAKeys - Configure hardware-backed authentication",
    "isAnyErrorResponse - Type guard for error responses"
  ]
}
